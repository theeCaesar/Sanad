# ---------------------------------------------------------------------------
# Sanad — environment template.
#
# Copy to `.env` and fill in. `.env` is gitignored and MUST NEVER be committed
# or included in a zip. In production these values come from Kubernetes Secrets
# (see k8s/secrets.example.yaml) or HashiCorp Vault — never from a file on disk.
#
# If you ever leak one of these: rotate it. Do not "just remove the file".
# ---------------------------------------------------------------------------

NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# --- Postgres -------------------------------------------------------------
# Sanad runs on Postgres, not Mongo. Field operations are transactional:
# stock decrements, cash reconciliation and job assignment must be atomic.
DATABASE_URL=postgres://sanad:sanad@localhost:5432/sanad
PG_IDLE_TIMEOUT_MS=30000

# --- Redis ----------------------------------------------------------------
# Used for: distributed rate limiting, sync-lock per device, socket adapter.
REDIS_URL=redis://localhost:6379

# --- Kafka ----------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=sanad
KAFKA_ENABLED=false

# --- Auth -----------------------------------------------------------------
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_string
JWT_DEVICE_SECRET=replace_me_with_a_third_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Field devices go offline for hours. A 15m access token would expire mid-shift,
# so devices hold a long-lived refresh token and re-mint on reconnect.
# See docs/SECURITY.md → "Offline auth".
DEVICE_REFRESH_TTL=90d

# --- Sync -----------------------------------------------------------------
SYNC_MAX_BATCH=200
SYNC_REPLAY_WINDOW_DAYS=14

# --- Object storage (Cloudflare R2) ---------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=sanad-media
R2_PUBLIC_BASE=

# --- Observability --------------------------------------------------------
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
METRICS_ENABLED=true

# --- CORS -----------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Deployment (used by docker-compose.prod.yml) --------------------------
# Must already resolve to this server before the first deploy, or TLS issuance
# fails.
DOMAIN=sanad.example.com
# Contact address for Let's Encrypt expiry notices.
ACME_EMAIL=

# Grafana is served publicly read-only via an anonymous Viewer role. This
# password is for the maintainer to log in and edit.
GRAFANA_USER=admin
GRAFANA_PASSWORD=

# Connection pool per process. Five services share Postgres's max_connections,
# so these must sum to comfortably less than it.
PG_POOL_MAX=30
