{
  "name": "sanad",
  "version": "1.0.0",
  "description": "Sanad — an offline-first field operations platform. Sync core + delivery and field-sales modules.",
  "main": "src/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "worker:outbox": "node src/workers/outboxPublisher.js",
    "migrate": "node-pg-migrate up -m src/db/migrations",
    "migrate:down": "node-pg-migrate down -m src/db/migrations",
    "seed": "node src/db/seeds/seed.js",
    "test": "npm run test:unit && npm run test:integration && npm run test:api",
    "test:unit": "jest --config jest.unit.config.js",
    "test:integration": "jest --config jest.integration.config.js",
    "test:api": "jest --config jest.api.config.js",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:api",
    "test:load": "k6 run tests/load/reconnect-storm.js",
    "test:coverage": "jest --config jest.unit.config.js --coverage",
    "lint": "eslint src tests",
    "test:contract": "jest --config jest.contract.config.js",
    "test:chaos": "jest --config jest.chaos.config.js",
    "test:rpc": "jest --config jest.rpc.config.js",
    "grpc:server": "node src/grpc/pricingServer.js",
    "demo:grpc": "node scripts/grpc-demo.js",
    "demo:graphql": "node scripts/graphql-demo.js"
  },
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.10",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.221.0",
    "@opentelemetry/resources": "^2.10.0",
    "@opentelemetry/sdk-node": "^0.221.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dataloader": "^2.2.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "graphql": "^16.9.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "morgan": "^1.10.0",
    "node-pg-migrate": "^7.6.1",
    "pg": "^8.12.0",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "pino-pretty": "^11.2.2",
    "prom-client": "^15.1.3",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "xss-clean": "^0.1.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^12.1.0",
    "@testcontainers/postgresql": "^10.9.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0",
    "testcontainers": "^10.11.0"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
